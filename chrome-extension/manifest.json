{
  "manifest_version": 3,
  "name": "First-Fin Browser Helper",
  "version": "2.1.0",
  "description": "Auto-fills Facebook Marketplace vehicle listings using inventory from your First-Fin dealer platform.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://app.firstfinancialcanada.com/*",
    "https://*.firstfinancialcanada.com/*",
    "https://www.facebook.com/*",
    "https://*.facebook.com/*",
    "https://*.fbcdn.net/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "FIRSTFIN-Inventory-Scanner.html",
    "default_title": "First-Fin Browser Helper"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.firstfinancialcanada.com/*",
        "https://*.firstfinancialcanada.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["fb-autofill.js"],
      "matches": ["https://www.facebook.com/*"]
    }
  ]
}
